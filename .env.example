# Copy this file to .env and adjust values for your machine.

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=wo_system
MYSQL_USERNAME=root
MYSQL_PASSWORD=root123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service discovery and config
NACOS_SERVER_ADDR=localhost:8848
NACOS_REMOTE_GRPC_IP=localhost
NACOS_SERVER_IP=192.168.213.100
SENTINEL_DASHBOARD_ADDR=localhost:8858
WO_INTERNAL_SERVICE_TOKEN=change-me-in-production

# Search / MQ / Vector DB
ELASTICSEARCH_URIS=http://localhost:9200
ROCKETMQ_NAME_SERVER=localhost:9876
ROCKETMQ_BROKER_IP=192.168.213.100
WORKORDER_EVENT_MQ_ENABLED=true
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=wo_knowledge_vectors

# AI model
DASHSCOPE_API_KEY=sk-placeholder

# Frontend
# Local frontend requests should enter through the gateway.
VITE_API_BASE_URL=http://localhost:8080/api
